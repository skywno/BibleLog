# Copy to .env and fill in credentials
DEBUG=true
JWT_SECRET=dev-change-me
INTERNAL_SERVICE_TOKEN=dev-internal-token

# storage: memory (unit tests) | scylla (docker-compose)
STORAGE_BACKEND=scylla

# ScyllaDB
SCYLLA_HOSTS=127.0.0.1
SCYLLA_PORT=9042
SCYLLA_KEYSPACE=biblelog

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# PostgreSQL
POSTGRES_URL=postgresql://biblelog:biblelog@localhost:5432/biblelog
POSTGRES_ENABLED=true

# Service URLs (docker-compose network hostnames)
USER_SERVICE_URL=http://user-service:8001
NOTE_SERVICE_URL=http://note-service:8002
SOCIAL_SERVICE_URL=http://social-service:8003
FEED_SERVICE_URL=http://feed-service:8004
READING_SERVICE_URL=http://reading-service:8005
AI_SERVICE_URL=http://ai-service:8006

# OAuth — https://console.cloud.google.com / Meta Developers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8000/auth

# AI provider: mock | openai | anthropic
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Feed
FEED_DEFAULT_LIMIT=20
FEED_LATEST_TTL_SECONDS=60
FEED_POPULAR_TTL_SECONDS=300

# OpenTelemetry (disabled by default for local dev without Jaeger)
OTEL_TRACES_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
STRUCTURED_LOGGING=true
DEPLOYMENT_ENVIRONMENT=development
